{
  "name": "@traice/collector",
  "version": "0.1.0",
  "description": "Local coding-agent usage collector for trAIce Internal Spend.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runtraice/traice-sdk.git",
    "directory": "packages/collector"
  },
  "bugs": {
    "url": "https://github.com/runtraice/traice-sdk/issues"
  },
  "homepage": "https://docs.runtraice.com/collectors",
  "engines": {
    "node": ">=20.9"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "traice-collector": "./dist/cli.cjs"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "@traice/protocol": "0.1.0",
    "commander": "^12.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "traice",
    "claude-code",
    "codex",
    "otel",
    "usage",
    "tokens",
    "llm",
    "collector"
  ]
}
